{
  "name": "library-llm-boilerplate",
  "version": "0.1.0",
  "description": "A strict TypeScript library boilerplate for npm packages built with LLM agents.",
  "license": "MIT",
  "author": "Dmitriy Ermolaev",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iusfof/library-llm-boilerplate.git"
  },
  "bugs": {
    "url": "https://github.com/iusfof/library-llm-boilerplate/issues"
  },
  "homepage": "https://github.com/iusfof/library-llm-boilerplate#readme",
  "keywords": [
    "typescript",
    "library",
    "boilerplate",
    "llm-agents"
  ],
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run build && npm run package:check",
    "clean": "rimraf dist coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint src test",
    "lint-staged": "lint-staged",
    "package:check": "HUSKY=0 npm_config_cache=.npm-cache npm pack --dry-run && HUSKY=0 npm_config_cache=.npm-cache publint",
    "prepare": "husky",
    "prepublishOnly": "npm run check",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "lint-staged": {
    "*.{ts,js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "eslint": "10.4.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.5",
    "prettier": "3.8.3",
    "publint": "0.3.21",
    "rimraf": "6.1.3",
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vitest": "4.1.7"
  }
}
